# =============================================================================
# Time-Off Microservice Configuration
# =============================================================================
# This file contains all configuration options for the Time-Off Microservice.
# Copy this file to .env and update the values for your environment.
#
# REQUIRED variables are marked with [REQUIRED]
# OPTIONAL variables have default values shown in brackets
#
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# PORT: HTTP server port (default: 3000)
# Valid range: 1-65535
PORT=3000

# NODE_ENV: Application environment (default: development)
# Valid values: development, production, test
NODE_ENV=development

# LOG_LEVEL: Logging verbosity level (default: info)
# Valid values: error, warn, info, debug, verbose
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# DATABASE_PATH: Path to SQLite database file (default: ./data/timeoff.db)
# The directory will be created automatically if it doesn't exist
DATABASE_PATH=./data/timeoff.db

# -----------------------------------------------------------------------------
# JWT Authentication [REQUIRED]
# -----------------------------------------------------------------------------
# JWT_SECRET: Secret key for signing JWT tokens [REQUIRED]
# IMPORTANT: Change this to a strong random value in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# JWT_EXPIRATION: Token expiration time (default: 24h)
# Format: https://github.com/vercel/ms (e.g., "60s", "2h", "7d")
JWT_EXPIRATION=24h

# -----------------------------------------------------------------------------
# HCM Integration [REQUIRED]
# -----------------------------------------------------------------------------
# HCM_BASE_URL: Base URL for HCM system API [REQUIRED]
# Example: https://api.hcm-system.com or http://localhost:3001 for local testing
HCM_BASE_URL=http://localhost:3001

# HCM_API_KEY: API key for authenticating with HCM system [REQUIRED]
# Obtain this from your HCM system administrator
HCM_API_KEY=your-hcm-api-key

# HCM_WEBHOOK_SECRET: Secret for validating HCM webhook signatures (optional)
# Used to verify that webhook requests are from the HCM system
HCM_WEBHOOK_SECRET=your-webhook-secret

# HCM_TIMEOUT_MS: Timeout for HCM API requests in milliseconds (default: 5000)
# Valid range: 1000-30000 (1-30 seconds)
HCM_TIMEOUT_MS=5000

# HCM_MAX_RETRIES: Maximum number of retry attempts for failed HCM requests (default: 3)
# Valid range: 0-10
HCM_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Balance Configuration
# -----------------------------------------------------------------------------
# BALANCE_STALE_THRESHOLD_MS: Time in milliseconds before cached balance is considered stale (default: 300000)
# Default: 300000 (5 minutes)
# Minimum: 1000 (1 second)
BALANCE_STALE_THRESHOLD_MS=300000

# -----------------------------------------------------------------------------
# Outbox Configuration
# -----------------------------------------------------------------------------
# OUTBOX_POLL_INTERVAL_MS: Interval for polling outbox events in milliseconds (default: 5000)
# Default: 5000 (5 seconds)
# Minimum: 1000 (1 second)
OUTBOX_POLL_INTERVAL_MS=5000

# =============================================================================
# Configuration Validation
# =============================================================================
# The application validates all configuration at startup and will fail to start
# if required variables are missing or invalid. Check the error messages for
# specific validation failures.
#
# For production deployments:
# 1. Generate a strong JWT_SECRET: openssl rand -base64 32
# 2. Set NODE_ENV=production
# 3. Configure HCM_BASE_URL and HCM_API_KEY for your HCM system
# 4. Set LOG_LEVEL=warn or LOG_LEVEL=error to reduce log verbosity
# 5. Adjust timeout and retry values based on your HCM system's performance
# =============================================================================

